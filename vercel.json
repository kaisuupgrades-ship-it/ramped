{
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/client-demo.html"
    },
    {
      "source": "/logo-concepts",
      "destination": "/logo-concepts.html"
    },
    {
      "source": "/one-pager",
      "destination": "/one-pager.html"
    },
    {
      "source": "/comparison",
      "destination": "/comparison.html"
    },
    {
      "source": "/book",
      "destination": "/book.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}