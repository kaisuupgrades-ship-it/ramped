{
  "functions": {
    "api/questionnaire.js": { "maxDuration": 120 },
    "api/generate-map.js":  { "maxDuration": 120 }
  },
  "rewrites": [
    { "source": "/demo",                    "destination": "/client-demo.html" },
    { "source": "/logo-concepts",           "destination": "/logo-concepts.html" },
    { "source": "/one-pager",               "destination": "/one-pager.html" },
    { "source": "/pricing-onepager",        "destination": "/pricing-onepager.html" },
    { "source": "/comparison",              "destination": "/comparison.html" },
    { "source": "/book",                    "destination": "/book.html" },
    { "source": "/privacy",                 "destination": "/privacy.html" },
    { "source": "/thanks",                  "destination": "/thanks.html" },
    { "source": "/admin",                   "destination": "/admin.html" },
    { "source": "/dashboard",               "destination": "/dashboard.html" },
    { "source": "/questionnaire-preview",   "destination": "/questionnaire-preview.html" },
    { "source": "/questionnaire",            "destination": "/questionnaire.html" },
    { "source": "/map/(.*)",                 "destination": "/map-result.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://va.vercel-scripts.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" }
      ]
    },
    {
      "source": "/:path*.:ext(css|js|svg|png|jpg|jpeg|woff2|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:page(index|book|comparison|client-demo|privacy|thanks|admin|dashboard).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
